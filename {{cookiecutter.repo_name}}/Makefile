PROJECT_TYPE := {{ cookiecutter.__project_type}}
PYTHON_DIR := {{ cookiecutter.__python_package_name }}
SCALA_DIR := {{ cookiecutter.__scala_package_name }}
PYTHON_VENV := .venv
PYTHON_VENV_PYTHON := $(PYTHON_VENV)/bin/python
PYTHON_DEV_DEPENDENCIES := pyspark databricks-dlt "ruff>=0.9.0" "pytest>=8.0.0"
SBT ?= sbt
SBT_FLAGS ?= --batch -Dsbt.ci=true -no-colors
SBT_CMD = $(SBT) $(SBT_FLAGS)

{% if cookiecutter.__databricks_enabled == "yes" %}
DATABRICKS_PROFILE ?= {{ cookiecutter.__databricks_profile }}
{% endif %}

SHELL := /bin/bash
.SHELLFLAGS := -eu -o pipefail -c

{% if cookiecutter.__databricks_enabled == "yes" %}
.PHONY: setup build test validate deploy ci help
{% else %}
.PHONY: setup build test ci help
{% endif %}

# Setup

setup:
ifeq ($(PROJECT_TYPE),python)
	@echo "Setting up Python environment..."
	cd $(PYTHON_DIR) && python3 -m venv $(PYTHON_VENV)
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pip install --upgrade pip
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pip install $(PYTHON_DEV_DEPENDENCIES)
endif

ifeq ($(PROJECT_TYPE),scala)
	@echo "Resolving Scala dependencies..."
	cd $(SCALA_DIR) && $(SBT_CMD) update
endif

ifeq ($(PROJECT_TYPE),hybrid)
	@echo "Setting up Hybrid project..."
	cd $(PYTHON_DIR) && python3 -m venv $(PYTHON_VENV)
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pip install --upgrade pip
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pip install $(PYTHON_DEV_DEPENDENCIES)
	cd $(SCALA_DIR) && $(SBT_CMD) update
endif


# Build


build:
ifeq ($(PROJECT_TYPE),python)
	@echo "Building Python project..."
	cd $(PYTHON_DIR) && python3 -m compileall src
endif

ifeq ($(PROJECT_TYPE),scala)
	@echo "Building Scala project..."
	cd $(SCALA_DIR) && $(SBT_CMD) compile
endif

ifeq ($(PROJECT_TYPE),hybrid)
	@echo "Building Hybrid project..."
	cd $(PYTHON_DIR) && python3 -m compileall src
	cd $(SCALA_DIR) && $(SBT_CMD) compile
endif


# Test


test:
ifeq ($(PROJECT_TYPE),python)
	@echo "Running Python tests..."
	@if [ ! -x "$(PYTHON_DIR)/$(PYTHON_VENV_PYTHON)" ]; then \
		echo "ERROR: Python environment not found. Run: make setup"; \
		exit 1; \
	fi
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pytest
endif

ifeq ($(PROJECT_TYPE),scala)
	@echo "Running Scala tests..."
	cd $(SCALA_DIR) && $(SBT_CMD) test
endif

ifeq ($(PROJECT_TYPE),hybrid)
	@echo "Running Hybrid tests..."
	@if [ ! -x "$(PYTHON_DIR)/$(PYTHON_VENV_PYTHON)" ]; then \
		echo "ERROR: Python environment not found. Run: make setup"; \
		exit 1; \
	fi
	cd $(PYTHON_DIR) && $(PYTHON_VENV_PYTHON) -m pytest
	cd $(SCALA_DIR) && $(SBT_CMD) test
endif


{% if cookiecutter.__databricks_enabled == "yes" %}
# Databricks Validate


validate:
	@echo "Validating Databricks bundle..."

	@if [ ! -f databricks.yml ]; then \
		echo "ERROR: databricks.yml not found."; \
		echo "The bundle config is expected to be generated by the template."; \
		echo "Recreate the project or restore databricks.yml before validating."; \
		exit 1; \
	fi

	databricks bundle validate -p $(DATABRICKS_PROFILE)

deploy:
	@echo "Deploying Databricks bundle..."
	databricks bundle deploy -p $(DATABRICKS_PROFILE)
{% endif %}

# Full CI Flow


{% if cookiecutter.__databricks_enabled == "yes" %}
ci: build test validate
{% else %}
ci: build test
{% endif %}


# Help


help:
	@echo ""
	@echo "Available commands:"
	@echo ""
	@echo "  make setup"
	@echo "  make build"
	@echo "  make test"
{% if cookiecutter.__databricks_enabled == "yes" %}
	@echo "  make validate"
	@echo "  make deploy"
{% endif %}
	@echo "  make ci"
	@echo ""